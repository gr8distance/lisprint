#!/bin/bash
set -e

INSTALL_DIR="/usr/local/bin"

echo "Building lisprint (release)..."
cargo build --release --manifest-path "$(dirname "$0")/../Cargo.toml"

echo "Installing to ${INSTALL_DIR}/lisprint..."
cp "$(dirname "$0")/../target/release/lisprint" "${INSTALL_DIR}/lisprint"

echo "Done! $(lisprint --version)"
